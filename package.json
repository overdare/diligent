{
  "name": "diligent",
  "private": true,
  "diligent": {
    "projectName": "Diligent"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "postinstall": "lefthook install --force && bash scripts/patch-hooks.sh",
    "validate:title": "bun scripts/validate-title.ts",
    "test": "NO_COLOR=1 FORCE_COLOR=0 bun test",
    "test:e2e": "bun test packages/e2e/",
    "web:dev": "bun run packages/web/src/server/index.ts --dev",
    "web:build": "bun run --cwd packages/web build",
    "debug-viewer:build": "bun run --cwd packages/debug-viewer build",
    "debug-viewer:start": "bun run --cwd packages/debug-viewer start",
    "debug-viewer:windows-exe": "bun run --cwd packages/debug-viewer build:windows-exe",
    "web:test": "bun test packages/web/",
    "lint": "NO_COLOR=1 FORCE_COLOR=0 bunx biome check .",
    "lint:fix": "NO_COLOR=1 FORCE_COLOR=0 bunx biome check --write .",
    "build": "bun build --compile packages/cli/src/index.ts --outfile dist/diligent",
    "build:linux-x64": "bun build --compile --target=bun-linux-x64 packages/cli/src/index.ts --outfile dist/diligent-linux-x64",
    "build:linux-arm64": "bun build --compile --target=bun-linux-arm64 packages/cli/src/index.ts --outfile dist/diligent-linux-arm64",
    "build:darwin-arm64": "bun build --compile --target=bun-darwin-arm64 packages/cli/src/index.ts --outfile dist/diligent-darwin-arm64",
    "build:darwin-x64": "bun build --compile --target=bun-darwin-x64 packages/cli/src/index.ts --outfile dist/diligent-darwin-x64",
    "build:windows-x64": "bun build --compile --target=bun-windows-x64 packages/cli/src/index.ts --outfile dist/diligent-windows-x64.exe",
    "build:all": "bun run build:linux-x64 && bun run build:linux-arm64 && bun run build:darwin-arm64 && bun run build:darwin-x64 && bun run build:windows-x64",
    "typecheck": "NO_COLOR=1 FORCE_COLOR=0 ./packages/protocol/node_modules/.bin/tsc --pretty false --noEmit -p packages/protocol/tsconfig.json && NO_COLOR=1 FORCE_COLOR=0 ./packages/plugin-sdk/node_modules/.bin/tsc --pretty false --noEmit -p packages/plugin-sdk/tsconfig.json && NO_COLOR=1 FORCE_COLOR=0 ./packages/core/node_modules/.bin/tsc --pretty false --noEmit -p packages/core/tsconfig.json && NO_COLOR=1 FORCE_COLOR=0 ./packages/cli/node_modules/.bin/tsc --pretty false --noEmit -p packages/cli/tsconfig.json && NO_COLOR=1 FORCE_COLOR=0 ./packages/web/node_modules/.bin/tsc --pretty false --noEmit -p packages/web/tsconfig.json",
    "typecheck:examples": "NO_COLOR=1 FORCE_COLOR=0 ./thirdparty/examples/external-tool-plugin/node_modules/.bin/tsc --pretty false --noEmit -p thirdparty/examples/external-tool-plugin/tsconfig.json",
    "desktop:dev": "bun run --cwd apps/desktop dev",
    "desktop:build": "bun run --cwd apps/desktop build",
    "package": "bun run --cwd apps/desktop scripts/package.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@playwright/test": "^1.58.2",
    "bun-types": "^1.3.10",
    "lefthook": "^2.1.2"
  }
}
