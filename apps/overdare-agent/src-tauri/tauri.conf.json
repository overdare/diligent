{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OVERDARE AI Agent",
  "identifier": "com.overdare.agent.desktop",
  "version": "0.1.4",
  "build": {
    "frontendDist": "../loading"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Diligent",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "externalBin": ["binaries/diligent-web-server", "binaries/rg"],
    "resources": {
      "resources/dist/client": "dist/client",
      "resources/bootstrap": "bootstrap"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  }
}
