{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Diligent",
  "identifier": "app.diligent.desktop",
  "version": "0.0.3",
  "build": {
    "frontendDist": "../loading"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Diligent",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "externalBin": ["binaries/diligent-web-server", "binaries/rg"],
    "resources": {
      "resources/dist/client": "dist/client",
      "resources/defaults": "defaults"
    }
  }
}
